<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- mDNS 公開・TCP listen のためのネットワーク権限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- マルチキャスト(mDNS)受信に必要な場合がある。要検証: NsdManager 利用時は不要なことが多い -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- フォアグラウンドサービス（画面オフでも公開継続） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- API 34+: FGS タイプごとの権限。外部デバイス(Mac)の表示先として動作するため connectedDevice を使用。
         要検証: dataSync 等の方が適切な可能性。connectedDevice は時間制限が無い点が常駐向き。 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- 通知（FGS の常駐通知表示。Android 13+ で実行時許可が必要） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Disproid">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Disproid.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ミラーリング映像の全画面表示。Mac の画面は横向き想定。
             AOA(USB Accessory) 接続時はこの Activity が accessory intent で直接起動される。 -->
        <activity
            android:name=".MirrorActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="sensorLandscape"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:theme="@style/Theme.Disproid.Mirror">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_ACCESSORY_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_ACCESSORY_ATTACHED"
                android:resource="@xml/accessory_filter" />
        </activity>

        <service
            android:name=".AdvertiseService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

    </application>
</manifest>
